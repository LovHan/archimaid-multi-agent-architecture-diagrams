# Copy to `.env` and fill in real values; `.env` is gitignored.

# OpenAI (or any OpenAI-compatible endpoint, e.g. Azure OpenAI / vLLM / Ollama-OpenAI-shim)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Per-agent model. Falls back to PLANNER_MODEL or OPENAI_MODEL if a specific one is missing.
PLANNER_MODEL=gpt-4o
CRITIC_MODEL=gpt-4o

# Optional: self-hosted Kroki for PNG rendering (default: https://kroki.io)
# KROKI_URL=https://kroki.example.com
# KROKI_TIMEOUT=30
